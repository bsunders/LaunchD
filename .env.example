# Required for a real LaunchDarkly connection (Server-side SDK key from Account settings → Projects → [env])
LAUNCHDARKLY_SDK_KEY=sdk-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Boolean flag key you create in LaunchDarkly (same key in Part 1 & 2 of the exercise)
FEATURE_FLAG_KEY=hero-component-v2

# Optional: programmatic "remediate" via REST (create an API token with Writer under Account settings → Authorization)
LAUNCHDARKLY_API_ACCESS_TOKEN=
LAUNCHDARKLY_PROJECT_KEY=
# Environment key as shown in the URL when you edit a flag (often "test" on trial accounts)
LAUNCHDARKLY_ENVIRONMENT_KEY=test
