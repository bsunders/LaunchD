# Copy this file to `.env` and replace placeholders. Do not commit `.env` with real secrets.

# LaunchDarkly → your project → Environments → Server-side SDK key (starts with sdk-).
LAUNCHDARKLY_SDK_KEY=sdk-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# LaunchDarkly → Flags → create a BOOLEAN flag with this exact flag key.
FEATURE_FLAG_KEY=hero-component-v2

# LaunchDarkly → AI Configs → completion-mode config with this key (optional extra credit).
LAUNCHDARKLY_AI_CONFIG_KEY=nimbus-support-chat

# LaunchDarkly → Metrics / experiments: custom event key must match this string for CTA tracking.
EXPERIMENT_CONVERSION_EVENT_KEY=nimbus-hero-cta-click

# OpenAI (optional): live chat completions. Leave empty to only prove AI Config evaluation in LD.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# --- Optional: LaunchDarkly Observability plugin (OpenTelemetry; see README) ---
# LAUNCHDARKLY_OBSERVABILITY=1
# OTEL_SERVICE_NAME=nimbus
# OTEL_SERVICE_VERSION=1.0.0
# (Optional) OTEL_EXPORTER_OTLP_ENDPOINT=…  # override; default is LaunchDarkly’s OTLP endpoint

# --- Optional: remediation scripts (hero-off.sh / remediate.sh) only — not read by the Python app ---
# LD_API_TOKEN=
# LD_PROJECT_KEY=default
# LD_ENVIRONMENT_KEY=test
# LD_FLAG_KEY=hero-component-v2

