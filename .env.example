LAUNCHDARKLY_SDK_KEY=sdk-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FEATURE_FLAG_KEY=hero-component-v2

# AI Config key — create a completion-mode AI Config in LaunchDarkly with this key (or change the value).
LAUNCHDARKLY_AI_CONFIG_KEY=nimbus-support-chat

# Custom event key sent when users click hero CTAs — use the same key in your Experiment metric.
EXPERIMENT_CONVERSION_EVENT_KEY=nimbus-hero-cta-click

# Required for live LLM replies (optional for proving AI Config evaluation only).
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
